{
  "name": "my-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=@repo/server --filter=@repo/web",
    "dev:web": "turbo dev --filter=@repo/web",
    "dev:server": "turbo dev --filter=@repo/server",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix --filter='@repo/*'",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "typecheck": "turbo typecheck",
    "codegen": "cargo run -p scripts-rs -- dev",
    "codegen:build": "cargo run -p scripts-rs -- build",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsx": "catalog:build-tools",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "packages/**/src/**/*.{ts,tsx}": [],
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,css}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.31.0"
}
